# DockGen self-hosting environment configuration
# Copy to .env and adjust before running `docker compose up --build -d`.

# Web UI port (public — also proxies /build-socket to the build service)
PORT=5172

# Internal Next.js port (not exposed publicly; proxied via PORT)
NEXT_INTERNAL_PORT=5174

# Test Build WebSocket port (internal; proxied at /build-socket on PORT)
BUILD_SERVICE_PORT=5173

# Optional: direct build service URL for local dev without the port proxy
# NEXT_PUBLIC_BUILD_SERVICE_URL=http://localhost:5173

# Required for Test Build — generate with: openssl rand -hex 32
BUILD_SERVICE_TOKEN=change-me-to-a-random-secret

# Comma-separated allowed origins for the build WebSocket service
BUILD_SERVICE_ORIGINS=http://localhost:5172,https://your-domain.example

# Optional: default access tokens for private repos (provider-specific)
# GITHUB_TOKEN=
# GITLAB_TOKEN=
# BITBUCKET_TOKEN=
# GITEA_TOKEN=
