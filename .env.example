# DockGen self-hosting environment configuration
# Copy to .env and adjust before running `docker compose up --build -d`.

# Web UI port (single container, process 1 of 2)
PORT=5172

# Test Build WebSocket port (single container, process 2 of 2)
BUILD_SERVICE_PORT=5173

# Optional: default GitHub personal access token used for cloning private repos
# when the user does not provide one in the UI. Leave blank to require per-request tokens.
# Create one at https://github.com/settings/tokens with `repo` scope.
GITHUB_TOKEN=
